# Reference: <https://postmarketos.org/devicepkg>
maintainer="Cesar Tamayo <macosmojave2@gmail.com>"
pkgname=device-xiaomi-platina
pkgdesc="Xiaomi Mi 8 Lite"
pkgver=5
pkgrel=7
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	firmware-qcom-adreno-a530
	firmware-xiaomi-platina
	linux-postmarketos-qcom-sdm660
	mkbootimg
	msm-firmware-loader
	postmarketos-base
	soc-qcom-sdm660
	"
makedepends="devicepkg-dev"
source="deviceinfo modules-initfs diag-pantalla.sh disable-suspend.start"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	install -Dm755 "$srcdir/diag-pantalla.sh" \
		"$pkgdir/usr/bin/diag-pantalla.sh"
	install -Dm755 "$srcdir/disable-suspend.start" \
		"$pkgdir/etc/local.d/disable-suspend.start"
}

