# Reference: <https://postmarketos.org/devicepkg>
pkgname=device-xiaomi-platina
pkgdesc="Xiaomi Mi 8 Lite"
pkgver=4
pkgrel=4
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
# soc-qcom-sdm660-rproc aporta rmtfs/tqftpserv: necesarios para que el modem
# (MSS) y el WiFi (WCN3990) carguen su firmware. El kernel pkgrel>=2 incluye el
# patch que habilita los nodos &wifi y &remoteproc_mss en el devicetree.
depends="
	iw
	linux-postmarketos-qcom-sdm660
	mkbootimg
	postmarketos-base
	soc-qcom-sdm660
	soc-qcom-sdm660-rproc
	wpa_supplicant
	"
makedepends="devicepkg-dev"
source="deviceinfo modules-initfs"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

nonfree_firmware() {
	pkgdesc="Wi-Fi/Modem firmware (wlanmdsp.mbn)"
	depends="firmware-xiaomi-platina"
	mkdir "$subpkgdir"
}

