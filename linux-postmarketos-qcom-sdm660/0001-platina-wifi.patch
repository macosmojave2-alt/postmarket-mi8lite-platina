--- a/arch/arm64/boot/dts/qcom/sdm660-xiaomi-platina.dts
+++ b/arch/arm64/boot/dts/qcom/sdm660-xiaomi-platina.dts
@@ -789,3 +789,25 @@
 	dr_mode = "peripheral";
 	extcon = <&extcon_usb>;
 };
+
+/*
+ * Enable Wi-Fi (Qualcomm WCN3990) and the modem (MSS) remoteproc. The WCN3990
+ * (ath10k_snoc) needs the modem subsystem alive to load its firmware. Both
+ * nodes exist in sdm630.dtsi but are disabled by default. The MSA SCM
+ * reassignment is fixed for this SoC by patch 0010 (assign only to MSS_MSA),
+ * so no qcom,msa-fixed-perm is needed here.
+ */
+&remoteproc_mss {
+	firmware-name = "postmarketos/mba.mbn", "postmarketos/modem.mdt";
+
+	status = "okay";
+};
+
+&wifi {
+	vdd-0.8-cx-mx-supply = <&vreg_l5a_0p848>;
+	vdd-1.8-xo-supply = <&vreg_l9a_1p8>;
+	vdd-1.3-rfa-supply = <&vreg_l6a_1p3>;
+	vdd-3.3-ch0-supply = <&vreg_l19a_3p3>;
+
+	status = "okay";
+};
