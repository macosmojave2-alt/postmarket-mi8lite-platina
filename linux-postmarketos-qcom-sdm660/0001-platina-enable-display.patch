From: pmOS Mi8Lite <macosmojave2@gmail.com>
Subject: [PATCH] arm64: dts: qcom: sdm660-xiaomi-platina: enable display + clean reserved-mem

Enable the display pipeline + BOE TD4320 panel (1080x2280), WLED (2 strings),
and model the LCDB VSP/VSN as fixed regulators (no mainline LCDB driver).

Also drop the platina removed_region@85800000 and cdsp-region@94e00000 reserved
memory nodes: removed_region overlaps qhee-code/rmtfs/smem/tz already defined in
sdm630.dtsi, and cdsp-region overlaps tzbuffer@94a00000 and is unreferenced
(SDM660 has no CDSP). Fixes the "OF: reserved mem: OVERLAP DETECTED" errors.

Signed-off-by: pmOS Mi8Lite <macosmojave2@gmail.com>
---
--- a/arch/arm64/boot/dts/qcom/sdm660-xiaomi-platina.dts	2026-06-18 13:24:57.678907346 -0500
+++ b/arch/arm64/boot/dts/qcom/sdm660-xiaomi-platina.dts	2026-06-18 13:27:30.418898294 -0500
@@ -63,16 +63,6 @@
 			no-map;
 		};
 
-		cdsp-region@94e00000 {
-			reg = <0x00 0x94e00000 0x00 0x600000>;
-			no-map;
-		};
-
-		removed_region@85800000 {
-			reg = <0x00 0x85800000 0x00 0x3700000>;
-			no-map;
-		};
-
 		framebuffer_memory@9d400000 {
 			reg = <0x0 0x9d400000 0x0 (1080 * 2280 * 4)>;
 			no-map;
@@ -89,6 +79,31 @@
 		regulator-boot-on;
 	};
 
+	/*
+	 * The panel positive/negative supplies (VSP/VSN, +/-5.4V) are
+	 * generated by the PM660L LCDB block, for which there is no mainline
+	 * driver yet (see sdm660-mainline issue #125). The bootloader leaves
+	 * LCDB enabled at boot; model VSP/VSN as fixed always-on regulators so
+	 * the panel can probe and uses the voltages the bootloader set up.
+	 */
+	panel_vsp: panel-vsp-regulator {
+		compatible = "regulator-fixed";
+		regulator-name = "panel_vsp";
+		regulator-min-microvolt = <5400000>;
+		regulator-max-microvolt = <5400000>;
+		regulator-always-on;
+		regulator-boot-on;
+	};
+
+	panel_vsn: panel-vsn-regulator {
+		compatible = "regulator-fixed";
+		regulator-name = "panel_vsn";
+		regulator-min-microvolt = <5400000>;
+		regulator-max-microvolt = <5400000>;
+		regulator-always-on;
+		regulator-boot-on;
+	};
+
 	cam_avdd_front_vreg: cam-avdd-front-vreg {
 		compatible = "regulator-fixed";
 		regulator-name = "cam-avdd-front-vreg";
@@ -236,7 +251,12 @@
 };
 
 &adreno_gpu {
-	status = "disabled";
+	status = "okay";
+};
+
+&adreno_gpu_zap {
+	firmware-name = "a512_zap.mbn";
+	memory-region = <&zap_shader_region>;
 };
 
 &blsp_i2c2 {
@@ -252,6 +272,8 @@
 &blsp_i2c4 {
 	status = "okay";
 
+	/* Touchscreen disabled for now: the Novatek controller does not ACK on
+	 * I2C (Error reading 0x78: -6); to be enabled when the touch is sorted. */
 	touchscreen@1 {
 		compatible = "novatek,nt36672a-ts";
 		reg = <0x1>;
@@ -262,6 +284,7 @@
 		reset-gpios = <&tlmm 66 GPIO_ACTIVE_LOW>;
 		touchscreen-size-x = <1080>;
 		touchscreen-size-y = <2280>;
+		status = "disabled";
 	};
 };
 
@@ -270,11 +293,11 @@
 };
 
 &gpucc {
-	status = "disabled";
+	status = "okay";
 };
 
 &mmcc {
-	status = "disabled";
+	status = "okay";
 };
 
 &pm660_gpios {
@@ -789,3 +812,67 @@
 	dr_mode = "peripheral";
 	extcon = <&extcon_usb>;
 };
+
+&mdss {
+	status = "okay";
+};
+
+&mdss_dsi0 {
+	status = "okay";
+
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	vdd-supply = <&vreg_l1b_0p925>;
+	vdda-supply = <&vreg_l1a_1p225>;
+
+	panel: panel@0 {
+		compatible = "xiaomi,platina-td4320", "boe,td4320";
+		reg = <0>;
+
+		iovcc-supply = <&vreg_l11a_1p8>;
+		vsp-supply = <&panel_vsp>;
+		vsn-supply = <&panel_vsn>;
+
+		reset-gpios = <&tlmm 53 GPIO_ACTIVE_LOW>;
+
+		backlight = <&pm660l_wled>;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&panel_reset_n &mdp_vsync_n>;
+
+		port {
+			panel_in: endpoint {
+				remote-endpoint = <&mdss_dsi0_out>;
+			};
+		};
+	};
+};
+
+&mdss_dsi0_out {
+	data-lanes = <0 1 2 3>;
+	remote-endpoint = <&panel_in>;
+};
+
+&mdss_dsi0_phy {
+	vcca-supply = <&vreg_l1b_0p925>;
+	status = "okay";
+};
+
+&mmss_smmu {
+	status = "okay";
+};
+
+&pm660l_wled {
+	qcom,switching-freq = <800>;
+	qcom,current-limit-microamp = <20000>;
+	qcom,num-strings = <2>;
+
+	status = "okay";
+};
+
+/* No DAI links wired up yet; q6asm-dai probe fails with -22. Disable until
+ * audio is configured, to keep the boot log clean. */
+&q6asmdai {
+	status = "disabled";
+};
