maintainer="Cesar Tamayo <macosmojave2@gmail.com>"
pkgname=firmware-xiaomi-platina
pkgver=2
pkgrel=0
pkgdesc="Firmware files for Xiaomi Mi 8 Lite (display zap + WiFi + modem)"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
options="!strip !check !archcheck !spdx !tracedeps pmb:cross-native"
makedepends="qca-swiss-army-knife python3"

# Modelado segun firmware-xiaomi-lavender:
# - a512_zap (zap shader del Adreno 512, necesario para el GPU/display) se toma
#   del blob propietario del vendor publicado por TheMuppets (igual que lavender,
#   pero del repo de platina). El paquete firmware-qcom-adreno-a530 BORRA el _zap
#   por estar firmado, asi que debe venir de aqui.
# - firmware-5.bin del WCN3990 se GENERA con ath10k-fwencoder (no es propietario).
# - board-2.bin + wlanmdsp.mbn vienen de los bdwlan.* extraidos de la placa
#   (calibracion WiFi especifica del dispositivo) -> tarball local.
# - modem MSS (mba/modem.mdt/.bNN) extraido de la particion modem del dispositivo
#   -> tarball local (necesario para WiFi/modem; lavender usa otro mecanismo).
_muppets_commit="d3c57407b34d03ff3597f67129c2bb0bdcac3005"
_muppets="proprietary_vendor_xiaomi_platina"

source="
	$_muppets-$_muppets_commit.tar.gz::https://github.com/TheMuppets/$_muppets/archive/$_muppets_commit.tar.gz
	gen-board-2.py
	$pkgname-bdwlan.tar.gz
	$pkgname-modem.tar.gz
"
builddir="$srcdir"

_fwdir="/lib/firmware/ath10k/WCN3990/hw1.0"

build() {
	cd "$srcdir"

	# 1. firmware-5.bin generico del WCN3990 (no propietario; se genera)
	ath10k-fwencoder --create \
		--features=wowlan,no-nwifi-decap-4addr-padding,allows-mesh-bcast,mgmt-tx-by-ref,non-bmi,single-chan-info-per-channel \
		--set-wmi-op-version=tlv --set-htt-op-version=tlv \
		--set-fw-api=5

	# 2. board-2.bin a partir de los bdwlan.* del dispositivo
	python3 gen-board-2.py "$srcdir/bdwlan" "$srcdir/bdwlan/board-2.json"
	cd "$srcdir/bdwlan"
	ath10k-bdencoder -c board-2.json -o "$srcdir/board-2.bin"
	cd "$srcdir"
}

package() {
	# WiFi: firmware-5.bin (generado) + board-2.bin (de la placa)
	install -Dm644 "$srcdir/firmware-5.bin" -t "$pkgdir/$_fwdir/"
	install -Dm644 "$srcdir/board-2.bin"    -t "$pkgdir/$_fwdir/"

	# Firmware del subsistema WiFi requerido por el WCN3990
	install -Dm644 "$srcdir/bdwlan/wlanmdsp.mbn" \
		"$pkgdir/lib/firmware/postmarketos/wlanmdsp.mbn"

	# Display: zap shader del GPU Adreno 512, desde TheMuppets (igual que lavender)
	install -Dm644 "$srcdir/$_muppets-$_muppets_commit/proprietary/vendor/firmware/a512_zap.elf" \
		"$pkgdir/lib/firmware/postmarketos/a512_zap.mbn"

	# Modem (MSS): mba.mbn + modem.mdt + segmentos modem.bNN
	install -dm755 "$pkgdir/lib/firmware/postmarketos"
	install -Dm644 "$srcdir/modem/mba.mbn"   -t "$pkgdir/lib/firmware/postmarketos/"
	install -Dm644 "$srcdir/modem/modem.mdt" -t "$pkgdir/lib/firmware/postmarketos/"
	install -Dm644 "$srcdir"/modem/modem.b*  -t "$pkgdir/lib/firmware/postmarketos/"
}

